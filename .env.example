# 服务端口
PORT=3001

# ===== 前端开发配置 =====
VITE_API_BASE_URL=http://localhost:3001

# ===== CORS 配置（可选） =====
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ===== 静态文件目录（可选，部署时使用） =====
# VIDEO2_DIST_DIR=./dist

# ===== 阿里云 OSS 配置 =====
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET=your_oss_bucket_name
OSS_REGION=oss-cn-beijing

# 开发环境 OSS（可选，用于区分开发/生产）
# OSS_ACCESS_KEY_ID_DEV=
# OSS_ACCESS_KEY_SECRET_DEV=
# OSS_BUCKET_DEV=
# OSS_REGION_DEV=

# ===== 阿里云 MPS 视频处理（可选，用于视频分割/转码） =====
# MPS_PIPELINE_ID=your_mps_pipeline_id

# ===== AI 平台 API Key =====
# GeekAI（首选）
GEEKAI_API_KEY=your_geekai_api_key

# 硅基流动 SiliconFlow（备选降级）
SILICONFLOW_API_KEY=your_siliconflow_api_key
